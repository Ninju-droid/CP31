#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

const ll MOD = 1e9+7;
const int MAXN = 1e6 + 5;
vector<ll>lg(MAXN,0);

void sp(vector<ll>&diff,vector<vector<ll>>&sparce,ll n,ll lg){
   for(ll i=0;i<=n;i++)sparce[i][0] = diff[i];
   for(ll j=1;j<=lg;j++){
      for(ll i=1;i+(1ll<<j)-1<=n;i++){
         sparce[i][j] = __gcd(sparce[i][j-1],sparce[i+(1ll<<(j-1))][j-1]);
      }
   }
}

void fun(){
   ll n,q;cin>>n>>q; 
   vector<ll>a(n+1),diff(n+1); 
   for(ll i=1;i<=n;i++)cin>>a[i];

   for(ll i=2;i<=n;i++)diff[i]=abs(a[i]-a[i-1]); 
   vector<vector<ll>>sparce(n+1,vector<ll>(lg[n]+1));
   sp(diff,sparce,n,lg[n]);
   while(q--){
      ll l,r; cin>>l>>r; 
      if(l==r){
         cout<<0<<" ";
         continue;
      }
      ll len = r - l;
      ll j = lg[len];
      ll val = __gcd(sparce[l+1][j], sparce[r - (1<<j) + 1][j]);
      cout<<val<<" ";
   }
   cout<<endl;
}

int main() {
#ifndef ONLINE_JUDGE
    freopen("Input.txt", "r", stdin);
    freopen("Output.txt", "w", stdout);
#endif  
   lg[1]=0; 
   for(ll i=2;i<MAXN;i++){
      lg[i] = lg[i/2]+1;
   } 
   int t = 1;
   cin>>t;
   while(t--)fun(); 
   return 0 ; 
}
