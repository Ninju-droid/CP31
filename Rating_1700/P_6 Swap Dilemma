#include <bits/stdc++.h>
using namespace std;
typedef long long ll;

ll parity(vector<ll>b){
    ll n = b.size()-1; 
    ll ans = 0 ; 
    for(ll i=1;i<=n;i++){
        while(b[i]!=i){
            swap(b[i],b[b[i]]);
            ans^=1; 
        }
    }
    return ans;
}

void fun() {
    ll n;cin>>n; 
    vector<ll>a(n+1),b(n+1); 
    map<ll,ll>pos_a;
    for(ll i=1;i<=n;i++){
        cin>>a[i];
        pos_a[a[i]]=i;  
    }
    bool pos = true; 
    for(ll i=1;i<=n;i++){
        cin>>b[i]; 
        if(pos_a.count(b[i])){
            b[i] = pos_a[b[i]]; 
        }
        else pos = false; 
    }
    if(pos==false){
        cout<<"NO"<<endl; 
        return; 
    }
    ll cnt = parity(b); 
    if(cnt%2)cout<<"NO"; 
    else cout<<"YES";
    cout<<endl;
}
int main() {
#ifndef ONLINE_JUDGE
    freopen("Input.txt", "r", stdin);
    freopen("Output.txt", "w", stdout);
#endif   
   int t = 1;
   cin>>t;
   while(t--)fun(); 
   return 0 ; 
}
